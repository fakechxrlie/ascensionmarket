datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String   @unique
  password  String
  role      String   @default("USER") // USER, BOOSTER, OWNER
  balance   Float    @default(0)
  level     Int      @default(1)
  xp        Int      @default(0)
  avatarUrl    String?
  ipAddress    String?
  isBanned     Boolean  @default(false)
  payoutMethod String?  // Crypto, CashApp, PayPal
  payoutAddress String?
  slogan       String?  @db.VarChar(100)
  lastUsernameChange DateTime?
  discordId    String?  @unique
  discordUsername String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userLogs     UserLog[]
  payoutRequests PayoutRequest[]
  orders       Order[]
  bids         Bid[]
  messages     Message[]
  applications BoosterApplication[]
  transactions Transaction[]
  reviewsReceived Review[]          @relation("BoosterReviews")
  reviewsGiven    Review[]          @relation("BuyerReviews")
}

model Order {
  id          String   @id @default(cuid())
  game        String
  startRank   String
  startDiv    String?
  startPts    String?
  targetRank  String
  targetDiv   String?
  targetPts   String?
  options     String?  // JSON string of options
  status      String   @default("OPEN") // OPEN, IN_PROGRESS, COMPLETED
  escrowAmount Float   @default(0)
  credentials String?   // Secure Vault: Stores platform, username, password, 2FA
  buyerId     String
  buyer       User     @relation(fields: [buyerId], references: [id])
  bids        Bid[]
  messages    Message[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  completedAt DateTime?
  review      Review?
}

model Bid {
  id          String   @id @default(cuid())
  amount      Float
  status      String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  boosterId   String
  booster     User     @relation(fields: [boosterId], references: [id])
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Message {
  id        String   @id @default(cuid())
  text      String
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  threadBoosterId String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model BoosterApplication {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  kycData       String
  games         String
  gameUsernames String
  skillProof    String
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Transaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  amount    Float
  currency  String   @default("USD")
  status    String   @default("PENDING") // PENDING, COMPLETED, FAILED
  method    String   @default("CRYPTO")
  invoiceId String?  // NOWPayments Invoice ID or Stripe Session ID
  bidId     String?  // Links the transaction directly to a Bid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id         String   @id @default(cuid())
  rating     Int
  comment    String?
  orderId    String   @unique
  order      Order    @relation(fields: [orderId], references: [id])
  boosterId  String
  booster    User     @relation("BoosterReviews", fields: [boosterId], references: [id])
  buyerId    String
  buyer      User     @relation("BuyerReviews", fields: [buyerId], references: [id])
  createdAt  DateTime @default(now())
}

model UserLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
}

model PayoutRequest {
  id        String   @id @default(cuid())
  amount    Float
  method    String
  address   String
  status    String   @default("PENDING") // PENDING, PAID, REJECTED
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
